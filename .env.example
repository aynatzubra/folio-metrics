# === DATABASE (Supabase) ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST@aws-1-eu-central-1.pooler.supabase.com:PORT/postgres"
# === AUTH ===
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_secure_secret_generated_locally
SECRET_DEMO_USER=demo@example.com
SECRET_DEMO_PASSWORD=demo123
DEMO_USER_ID=demo

# === MODES
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

NEXT_PUBLIC_ANALYTICS_MODE=prod

# === SUPABASE (Optional for Client SDK) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=